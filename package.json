{
  "name": "mcp-execution-ledger",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Durable execution layer for MCP tool calls with immutable execution logs, checkpoint-based recovery, and replay.",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "nitrostack-cli dev",
    "build:assets": "node ./scripts/build-assets.mjs",
    "build": "nitrostack-cli build && npm run build:assets",
    "start": "npm run build && nitrostack-cli start",
    "start:prod": "nitrostack-cli start",
    "prepare": "echo Skipping prepare during container install", 
    "postinstall": "node -e \"const fs=require('fs'); if(fs.existsSync('./scripts/postinstall.mjs')) import('./scripts/postinstall.mjs'); else console.log('Skipping postinstall during container dependency install');\"",
    "upgrade": "nitrostack-cli upgrade",
    "install:all": "nitrostack-cli install",
    "widget": "npm --prefix src/widgets"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": ">=0.1.0",
    "@nitrostack/core": "^1.0.13",
    "@types/sqlite3": "^3.1.11",
    "dotenv": "^16.3.1",
    "sqlite3": "^6.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nitrostack/cli": "^1.0.14",
    "@types/node": "^22.10.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Tallam Sai Madhav",
  "nitrostack": {
    "skillsVersion": "1.0.0"
  },
  "allowScripts": {
    "esbuild@0.24.2": true,
    "sqlite3@6.0.1": true
  }
}
